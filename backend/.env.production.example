# PostgreSQL credentials for the db container
POSTGRES_DB=mkomplekt
POSTGRES_USER=mkomplekt
POSTGRES_PASSWORD=change-this-db-password

# Full database URL for Django
DATABASE_URL=postgresql://mkomplekt:change-this-db-password@db:5432/mkomplekt

# Django
SECRET_KEY=replace-with-a-long-random-secret
APP_ENV=production
TIME_ZONE=Asia/Yakutsk

# Domain and frontend access
ALLOWED_HOSTS=example.ru,www.example.ru,api.example.ru
CORS_ORIGINS=https://example.ru,https://www.example.ru
CSRF_TRUSTED_ORIGINS=https://example.ru,https://www.example.ru,https://api.example.ru

# Cookies and reverse proxy
COOKIE_SECURE=true
COOKIE_DOMAIN=
USE_X_FORWARDED_HOST=true
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
X_FRAME_OPTIONS=DENY

# Media
MEDIA_ROOT=/app/media
MEDIA_URL=/media

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=600
